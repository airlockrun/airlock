# Dockerfile.frontend — Vue 3 SPA (build + serve via Caddy)

# --- Build ---
FROM node:22-alpine AS builder

WORKDIR /app
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm ci
COPY frontend/ .
RUN npm run build

# --- Runtime ---
FROM caddy:2-alpine

COPY --from=builder /app/dist /srv
