# Airlock LAPTOP TEST configuration.
#
# These are dummy secrets for trying airlock on your machine. Do NOT
# reuse this file for a real install — anything encrypted under these
# keys is effectively public, and the JWT secret would let anyone with
# this file forge sessions on your instance.
#
# Quickstart:
#   1. cp .env.local.example .env
#   2. docker compose -f docker-compose.yml -f docker-compose.local.yml up -d
#   3. Trust Caddy's local CA (one-time, eliminates the browser warning):
#        docker compose exec caddy caddy trust 2>/dev/null || true
#        docker compose cp caddy:/data/caddy/pki/authorities/local/root.crt /tmp/airlock-ca.crt
#        # then import /tmp/airlock-ca.crt into your OS / browser trust store.
#      Skipping this step is fine — your browser will just show a warning
#      you can click through on first visit to each subdomain.
#   4. Open https://airlock.localhost:24443 and grab the activation code:
#        docker compose exec airlock cat /var/lib/airlock/activation_code.txt
#
# *.localhost resolves to 127.0.0.1 automatically (RFC 6761) in every
# modern browser, so no DNS, no /etc/hosts, no public-domain dance.
DOMAIN=airlock.localhost

# Non-default ports so we don't collide with whatever else is bound to
# 80/443 on your laptop (system web server, another docker stack, etc.).
# These are in the rarely-used 24xxx range; change them if you happen
# to have something there. PUBLIC_URL / S3_URL_PUBLIC below MUST carry
# the same HTTPS_PORT — the airlock backend reads scheme+port from
# PUBLIC_URL when building per-agent {slug}.airlock.localhost URLs, so
# signed asset URLs validate against what Caddy actually serves.
HTTP_PORT=24080
HTTPS_PORT=24443

# Browser-facing URLs. Both must include :${HTTPS_PORT}.
PUBLIC_URL=https://airlock.localhost:24443
S3_URL_PUBLIC=https://s3.airlock.localhost:24443

# Test secrets. Predictable on purpose — laptop only.
ENCRYPTION_KEY=00000000000000000000000000000000000000000000000000000000deadbeef
JWT_SECRET=local-jwt-not-for-production-use-only-replace-for-any-real-deploy

# Postgres + S3 defaults: same as prod, fine for laptop.
POSTGRES_USER=airlock
POSTGRES_PASSWORD=airlock
POSTGRES_DB=airlock
S3_ACCESS_KEY=airlock
S3_SECRET_KEY=local-s3-secret-not-for-production
