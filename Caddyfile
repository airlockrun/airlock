# Airlock self-host Caddy config.
#
# TLS strategy: on-demand, validated against airlock's /caddy/ask endpoint.
# Caddy issues a fresh cert per agent subdomain on first request via Let's
# Encrypt's HTTP-01 challenge. No DNS provider credentials needed.
#
# Tradeoff: Let's Encrypt rate-limits 50 cert issuances per registered domain
# per week (renewals count). Comfortable for installations with <30 agents;
# above that, see README "Wildcard DNS-01" section to switch to a single
# wildcard cert that sidesteps the rate limit entirely.
{
	# Let's Encrypt account email — receive cert expiry warnings here.
	# Uncomment and edit once you have one (or set ACME_EMAIL in .env and
	# replace the literal address below with {$ACME_EMAIL}).
	# email you@example.com

	on_demand_tls {
		ask http://airlock:8080/caddy/ask
	}
}

# Apex domain: the dashboard SPA + airlock REST/WebSocket API.
{$DOMAIN} {
	# /auth/relay is a frontend SPA route — the landing page for the
	# subdomain relay-login flow. Must be matched BEFORE @backend so it
	# doesn't get swallowed by the /auth/* matcher. The backend serves
	# POST /auth/relay-code, which the SPA calls from this page.
	@spa_relay path /auth/relay
	handle @spa_relay {
		reverse_proxy frontend:80
	}
	@backend path /api/* /auth/* /auth-external /ws /webhooks/* /health
	handle @backend {
		reverse_proxy airlock:8080
	}
	handle {
		reverse_proxy frontend:80
	}
}

# Public S3 — for presigned URLs that LLM providers (OpenAI, Anthropic,
# etc.) fetch directly. The internal hostname `minio:9000` isn't reachable
# from the public internet, so any presigned URL airlock generates for
# LLM-bound content (image inputs, attachments) needs to point here.
#
# Uses on_demand like the wildcard below: Caddy's auto-https eager-issuance
# logic skips hostnames that overlap with a wildcard block, which means a
# `tls { issuer acme }` directive on s3.{$DOMAIN} doesn't actually trigger
# startup issuance — the cert ends up undefined and the first TLS handshake
# aborts with SSL_ERROR_INTERNAL_ERROR_ALERT. on_demand sidesteps the
# overlap entirely: Caddy issues lazily on the first request, validating
# against /caddy/ask on airlock (which whitelists the "s3" slug — see
# api/caddy.go). First connection takes ~5-10s while LE issues; subsequent
# connections are cached.
#
# header_up Host: airlock signs presigned URLs against host=s3.{$DOMAIN}.
# Caddy's reverse_proxy default rewrites Host to the upstream's address,
# which would invalidate the signature when MinIO recomputes it. Preserve
# the original Host so MinIO sees what airlock signed.
s3.{$DOMAIN} {
	tls {
		on_demand
	}
	reverse_proxy minio:9000 {
		header_up Host {host}
	}
}

# Wildcard subdomains: per-agent custom routes ({slug}.{$DOMAIN}).
# airlock's SubdomainProxy handles routing internally — Caddy just needs
# to terminate TLS and forward the request.
*.{$DOMAIN} {
	tls {
		on_demand
	}
	reverse_proxy airlock:8080
}
