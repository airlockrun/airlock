# Develop-against-source configuration.
#
# Pairs with docker-compose.dev.yml — postgres + rustfs + caddy run in
# containers, airlock + frontend run natively from your source tree.
# Fast iteration (no image rebuilds on Go/Vue edits), debugger attach,
# live reload — at the cost of needing a Go + Node toolchain locally.
#
# Quickstart:
#   1. cp .env.dev.example .env
#   2. Edit DOMAIN below (laptop-only → keep airlock.localhost; shared
#      dev server → switch to 1.2.3.4.nip.io with your machine's IP).
#   3. Edit AGENT_LIBS_PATH if you want the agent build pipeline to
#      pick up live edits in your sibling agentsdk / goai / sol checkouts.
#   4. docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d
#   5. In another terminal:
#        go run ./cmd/airlock serve
#        cd frontend && pnpm dev
#   6. Open https://${DOMAIN}, accept the browser warning on first visit
#      (or trust Caddy's local CA permanently — see .env.local.example
#      for the snippet).

# Public hostname Caddy serves under. *.localhost works fine when you're
# only hitting it from the same machine; for cross-PC access use a public
# wildcard DNS service like nip.io (1.2.3.4.nip.io resolves to 1.2.3.4)
# or your own real subdomain.
DOMAIN=airlock.localhost

# Caddy upstreams. Defaults reach the host network; only override if
# you're tunnelling or running airlock/frontend on a non-standard port.
AIRLOCK_UPSTREAM=host.docker.internal:8080
FRONTEND_UPSTREAM=host.docker.internal:5173

# Test secrets. Predictable on purpose — dev only.
ENCRYPTION_KEY=00000000000000000000000000000000000000000000000000000000deadbeef
JWT_SECRET=local-jwt-not-for-production-use-only-replace-for-any-real-deploy

# Postgres + S3 defaults.
POSTGRES_USER=airlock
POSTGRES_PASSWORD=airlock
POSTGRES_DB=airlock
S3_ACCESS_KEY=airlock
S3_SECRET_KEY=local-s3-secret-not-for-production

# --- Knobs the natively-running airlock binary reads from .env too ---
#
# These don't affect the docker-compose services; they're here so a
# single .env covers both `docker compose` and `go run ./cmd/airlock`.

# Public URL the backend reports / signs URLs against. Must match
# DOMAIN + the Caddy-served port (default https/443; if you bind Caddy
# elsewhere via override.yml, include the port here too).
PUBLIC_URL=https://airlock.localhost

# Postgres + S3 endpoints the native binary connects to. The dev overlay
# exposes both on 127.0.0.1 (postgres:5432, rustfs:9090) so the host-side
# airlock can reach them without joining the docker network.
DATABASE_URL=postgres://airlock:airlock@127.0.0.1:5432/airlock?sslmode=disable
S3_URL=http://127.0.0.1:9090
# Externally-reachable S3 hostname for presigned URLs the browser/LLMs
# follow. Caddy serves s3.${DOMAIN} → rustfs:9000.
S3_URL_PUBLIC=https://s3.airlock.localhost

# Where the agent build pipeline finds agentsdk / goai / sol source.
# Empty = airlock extracts /libs/ from the agent-builder image (the
# release flow). Set to a host path if you want live edits to those
# libs to flow into per-agent builds without rebuilding the
# agent-builder image. Typical: the parent of this airlock checkout.
# AGENT_LIBS_PATH=/home/you/code/airlockrun

# Toolserver / runtime image overrides. The in-code defaults
# (config.DefaultAgent{Builder,Base}Image) already pin to the matching
# ghcr release for this airlock version. Only set these if you've built
# a custom toolserver/runtime locally and want to point at it instead.
# AGENT_BUILDER_IMAGE=agent-builder:dev
# AGENT_BASE_IMAGE=airlock-agent-base:dev
