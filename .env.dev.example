# Airlock develop-against-source preset — copy to .env for `make dev`.
#
# Model: postgres + rustfs + caddy run as containers (the bundled-db profile);
# airlock + the frontend run natively from your source tree. Fast iteration (no
# image rebuilds on Go/Vue edits), debugger attach — at the cost of a local Go +
# Node toolchain. `make dev` brings up the infra subset, then runs the binary
# and `pnpm watch` for you:
#
#   1. cp .env.dev.example .env
#   2. Optionally set AGENT_LIBS_PATH to use live agentsdk/goai/sol source.
#   3. cd frontend && pnpm install && cd ..     # one-time
#   4. make dev
#
# Caddy serves frontend/dist as static files; vite runs in watch-build mode
# (NOT `vite dev`) — no dev server on the network, closing the vite-dev attack
# surface. Trade-off vs HMR: manual browser refresh on edits.

# --- Ingress (read by the caddy container) ---

# Loopback-only HTTP + localhost (RFC 6761, no DNS).
# Ingress is independent of native development: replace this block with a
# wildcard, tunnel, manual, or proxy configuration when remote access is needed.
DOMAIN=localhost
TLS_MODE=local
HTTP_PORT=42080

# Only the bundled infra runs in containers; airlock/frontend are native, so
# `make dev` starts the active ingress services plus postgres and rustfs.
COMPOSE_PROFILES=bundled-db,bundled-s3,caddy-local

# Caddy → the native airlock binary on the host (not the airlock container).
AIRLOCK_UPSTREAM=host.docker.internal:8080

# SPA served as static files from frontend/dist (vite `pnpm watch` output)
# instead of proxying the frontend container. These flip caddy/routes.caddy's
# (spa) snippet from reverse_proxy to file_server (see .env.example defaults).
# Quoted so `make dev` can `source .env` for the native binary without the shell
# choking on the spaces/braces (docker compose strips the quotes either way).
SPA_ROOT_LINE="root * /srv/dist"
SPA_SERVE_LINE="try_files {path} /index.html"
SPA_SERVE_LINE2=file_server

# --- Secrets (dummy — dev only, predictable on purpose) ---
ENCRYPTION_KEY=00000000000000000000000000000000000000000000000000000000deadbeef
JWT_SECRET=local-jwt-not-for-production-use-only-replace-for-any-real-deploy
REVERSE_PROXY_AUTH_SECRET=local-caddy-airlock-proxy-secret-not-for-production
POSTGRES_USER=airlock
POSTGRES_PASSWORD=local-postgres-superuser-password-not-for-production
AIRLOCK_DB_PASSWORD=local-airlock-application-password-not-for-production
POSTGRES_DB=airlock
S3_ACCESS_KEY=airlock
S3_SECRET_KEY=local-s3-secret-not-for-production

# --- Knobs the native airlock binary reads from this same .env ---
#
# (The caddy container ignores these; they wire up `go run ./cmd/airlock`.)

# Public URL the backend reports / signs URLs against (DOMAIN + the Caddy port).
PUBLIC_URL=http://localhost:42080

# Postgres + S3 endpoints the native binary connects to. `make dev` applies
# docker-compose.dev.yml, which publishes the bundled services on uncommon
# loopback host ports to avoid collisions with host services.
DB_PORT_HOST=42432
S3_PORT_HOST=42900
DATABASE_URL=postgres://airlock_app:local-airlock-application-password-not-for-production@127.0.0.1:42432/airlock?sslmode=disable
# Per-agent DSNs are assembled from DB_* (not DATABASE_URL); the bundled
# Postgres has no TLS, so this must be disable or agent migration validation
# fails with "SSL is not enabled on the server".
DB_SSL_MODE=disable
S3_URL=http://127.0.0.1:42900
S3_URL_PUBLIC=http://s3.localhost:42080

# Agent + toolserver containers attach to DOCKER_NETWORK and call back to
# airlock at API_URL_AGENT. With airlock native (not a container) these point at
# the bundled compose network and the host gateway (caddy/agents reach the host
# binary via host.docker.internal). Without them agents default to
# localhost:8080 (talking to themselves) on an empty network.
DOCKER_NETWORK=airlock
AGENT_NETWORK_PER_AGENT=false
API_URL_AGENT=http://host.docker.internal:8080
AGENT_HOST_GATEWAY=true

# Airlock-brokered httpRequest and connection calls may reach host LAN/VPN
# services. Set empty to restrict those calls to public destinations.
AGENT_HTTP_PRIVATE_CIDRS=0.0.0.0/0,::/0

# Distinct namespace so a dev instance and a prod stack can share the host
# daemon without reaping each other's agents.
AIRLOCK_INSTANCE_ID=airlock-dev

# UFW note: if the firewall is active, containers can't reach the native airlock
# on the host until you allow the bundled network's subnet → :8080. Find it with:
#   docker network inspect airlock -f '{{(index .IPAM.Config 0).Subnet}}'
# then: sudo ufw allow from <subnet> to any port 8080 proto tcp

# Host-writable data dirs. Default to the in-container /var/lib/airlock (libs
# cache, agent git repos, activation code), which the native binary can't write.
# Point them at home and create once:
#   mkdir -p ${HOME}/.local/share/airlock/{libs,agents}
AGENT_LIBS_CACHE_DIR=${HOME}/.local/share/airlock/libs
AGENT_REPOS_PATH=${HOME}/.local/share/airlock/agents
ACTIVATION_CODE_FILE=${HOME}/.local/share/airlock/activation_code.txt

# Where the agent build pipeline finds agentsdk / goai / sol source. Empty =
# airlock extracts /libs/ from the agent-builder image. Set to a host path to
# flow live lib edits into per-agent builds. Typical: the parent of this
# airlock checkout.
# AGENT_LIBS_PATH=/home/you/code/airlockrun

# Toolserver / runtime image overrides. The in-code defaults already pin to the
# matching ghcr release for this airlock version. Only set these if you built a
# custom toolserver/runtime locally and want to point at it instead.
# AGENT_BUILDER_IMAGE=agent-builder:dev
# AGENT_BASE_IMAGE=airlock-agent-base:dev
