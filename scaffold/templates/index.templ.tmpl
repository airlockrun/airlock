package views

templ Index() {
	@Layout("Home") {
		<header class="mb-10">
			<h1 class="text-3xl font-semibold tracking-tight">Hello from your new agent</h1>
			<p class="mt-2 text-neutral-600">This is the default placeholder homepage.</p>
		</header>

		<section class="rounded-[var(--radius-card)] border border-neutral-200 bg-white p-6 shadow-sm">
			<h2 class="text-xl font-semibold">What now?</h2>
			<p class="mt-3 text-neutral-700">Open a chat with this agent and ask it to do something — for example:</p>
			<ul class="mt-3 list-disc space-y-1 pl-5 text-neutral-700">
				<li>"Replace this homepage with a dashboard for my tasks"</li>
				<li>"Add a webhook that posts new GitHub issues to Slack"</li>
				<li>"Schedule a daily digest of unread emails"</li>
			</ul>
			<p class="mt-4 text-sm text-neutral-500">
				The agent will edit its own code, rebuild itself, and replace this page.
			</p>
		</section>
	}
}
