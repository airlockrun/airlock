package views

templ Index() {
	@Layout("Home") {
		<div style="max-width: 640px; margin: 4rem auto; padding: 0 1rem; font-family: system-ui, sans-serif; line-height: 1.6;">
			<h1 style="margin-bottom: 0.5rem;">👋 Hello from your new agent</h1>
			<p style="color: #666; margin-top: 0;">This is the default placeholder homepage.</p>

			<h2 style="margin-top: 2rem;">What now?</h2>
			<p>
				Open a chat with this agent and ask it to do something — for example:
			</p>
			<ul>
				<li>"Replace this homepage with a dashboard for my tasks"</li>
				<li>"Add a webhook that posts new GitHub issues to Slack"</li>
				<li>"Schedule a daily digest of unread emails"</li>
			</ul>

			<p style="color: #666; font-size: 0.9rem; margin-top: 2rem;">
				The agent will edit its own code, rebuild itself, and replace this page.
			</p>
		</div>
	}
}
