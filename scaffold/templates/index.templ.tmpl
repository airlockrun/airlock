package views

templ Index(view HomeView) {
	@Layout(view.Title) {
		<header class="mb-8">
			<h1 class="text-3xl font-semibold">{ view.Title }</h1>
			<p class="mt-2 text-base-content/70">{ view.Subtitle }</p>
		</header>

		<section class="card bg-base-200 shadow-sm">
			<div class="card-body">
				<h2 class="card-title">What now?</h2>
				<p>Open a chat with this agent and ask it to do something — for example:</p>
				<ul class="list-disc space-y-1 pl-5">
					for _, ex := range view.Examples {
						<li>{ ex }</li>
					}
				</ul>
				<p class="mt-4 text-sm text-base-content/60">
					The agent will edit its own code, rebuild itself, and replace this page.
				</p>
			</div>
		</section>
	}
}
