package views

templ Index() {
	@Layout("Home") {
		<hgroup>
			<h1>Hello from your new agent</h1>
			<p>This is the default placeholder homepage.</p>
		</hgroup>

		<article>
			<h2>What now?</h2>
			<p>Open a chat with this agent and ask it to do something — for example:</p>
			<ul>
				<li>"Replace this homepage with a dashboard for my tasks"</li>
				<li>"Add a webhook that posts new GitHub issues to Slack"</li>
				<li>"Schedule a daily digest of unread emails"</li>
			</ul>
			<footer><small>The agent will edit its own code, rebuild itself, and replace this page.</small></footer>
		</article>
	}
}
