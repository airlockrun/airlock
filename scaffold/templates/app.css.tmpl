/* Tailwind v4 + DaisyUI v5 source. The build pipeline runs
 *   tailwindcss -i styles/app.css -o views/static/app.css --minify
 * and the compiled output is embedded into the agent and served at
 * /static/app.{hash}.css. The DaisyUI plugin is loaded from a fixed
 * path the build environment provides. Theming: see AGENTS.md.
 */

@import "tailwindcss";

@plugin "/usr/local/lib/tailwind/daisyui.mjs" {
  themes: light --default, dark --prefersdark;
}
