package main

import (
	"context"
	"net/http"

	"{{.Module}}/handlers"
	"{{.Module}}/views"

	"github.com/airlockrun/agentsdk"
)

func main() {
	newAgent().Serve()
}

// newAgent builds the agent and registers everything on it. main() and the
// tests both go through here, so a test can exercise the fully-wired agent via
// agent.Handler(). Keep registration in this function — don't inline it back
// into main(), or the tests stop compiling.
func newAgent() *agentsdk.Agent {
	agent := agentsdk.New(agentsdk.Config{
		Description: "New agent — update this description after implementation",
	})

	agent.RegisterRoute(&agentsdk.Route{
		Method:      "GET",
		Path:        "/",
		Handler:     handlers.Home,
		Access:      agentsdk.AccessUser,
		Description: "Default placeholder homepage — replace this once the agent has real routes",
	})

	// Static asset route — serves the compiled Tailwind stylesheet (and any
	// other files embedded in views/) under a content-hashed URL the
	// scaffold's layout already references via views.AppCSSPath. The route
	// is public so unauthenticated browsers can load the stylesheet.
	agent.RegisterRoute(&agentsdk.Route{
		Method: "GET",
		Path:   "/static/{name}",
		Handler: func(ctx context.Context, w http.ResponseWriter, r *http.Request) {
			if r.PathValue("name") == views.AppCSSName {
				w.Header().Set("Content-Type", "text/css; charset=utf-8")
				w.Header().Set("Cache-Control", "public, max-age=31536000, immutable")
				_, _ = w.Write(views.AppCSS)
				return
			}
			http.NotFound(w, r)
		},
		Access:      agentsdk.AccessPublic,
		Description: "Compiled stylesheet and other embedded static files",
	})

	// Sol will add RegisterTool, RegisterWebhook, RegisterCron, RegisterConnection calls here.
	return agent
}
