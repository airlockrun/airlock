version: "2"
sql:
  - engine: "postgresql"
    queries: "db/queries"
    schema: "db/migrations"
    gen:
      go:
        package: "db"
        out: "internal/db"
        # database/sql (lib/pq) to match agentsdk's Agent.DB(), which returns an
        # *AgentDB over *sql.DB you pass to the generated New(). uuid maps to
        # github.com/google/uuid; nullable columns use sql.Null*.
        sql_package: "database/sql"
        emit_json_tags: true
        emit_empty_slices: true
