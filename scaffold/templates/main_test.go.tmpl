package main

import (
	"bytes"
	"context"
	"io"
	"net/http"
	"net/http/httptest"
	"testing"

	"{{.Module}}/views"

	"github.com/airlockrun/agentsdk/agenttest"
)

// TestStaticStylesheetServed checks that the compiled stylesheet round-trips
// through the real /static/{name} route: a GET of views.AppCSSPath returns the
// embedded CSS with a text/css content type, and an unknown name 404s. This runs
// the request through the actual mux (agent.Handler()), so it catches a route
// that is registered but never writes the bytes — the kind of silent "page
// loads with no styling" bug that compiles and serves a 200 but an empty body.
func TestStaticStylesheetServed(t *testing.T) {
	agenttest.NewEnv(t)

	srv := httptest.NewServer(newAgent().Handler())
	defer srv.Close()

	resp, err := http.Get(srv.URL + views.AppCSSPath)
	if err != nil {
		t.Fatal(err)
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusOK {
		t.Fatalf("GET %s = %d, want 200", views.AppCSSPath, resp.StatusCode)
	}
	if ct := resp.Header.Get("Content-Type"); ct != "text/css; charset=utf-8" {
		t.Errorf("Content-Type = %q, want text/css; charset=utf-8", ct)
	}
	body, err := io.ReadAll(resp.Body)
	if err != nil {
		t.Fatal(err)
	}
	if len(body) == 0 {
		t.Fatal("stylesheet body is empty — the route served a 200 with no CSS")
	}
	if !bytes.Equal(body, views.AppCSS) {
		t.Errorf("served body (%d bytes) does not match embedded views.AppCSS (%d bytes)", len(body), len(views.AppCSS))
	}

	miss, err := http.Get(srv.URL + "/static/does-not-exist.css")
	if err != nil {
		t.Fatal(err)
	}
	miss.Body.Close()
	if miss.StatusCode != http.StatusNotFound {
		t.Errorf("GET unknown static file = %d, want 404", miss.StatusCode)
	}
}

// TestDBMigratesAndConnects is the worked example for DB-backed tests.
// agenttest.UseDB points the agent at $TEST_DB_URL, resets the schema, and
// applies db/migrations — skipping the test when no test database is set. Once
// you add tables, query through agent.DB() (which sqlc's New() accepts) and
// assert on the results; this run just checks the migrated schema is reachable.
func TestDBMigratesAndConnects(t *testing.T) {
	agenttest.NewEnv(t)
	a := newAgent()
	agenttest.UseDB(t, a) // skips unless $TEST_DB_URL is set

	if err := a.DB().PingContext(context.Background()); err != nil {
		t.Fatalf("agent DB not reachable after migrate: %v", err)
	}
}
