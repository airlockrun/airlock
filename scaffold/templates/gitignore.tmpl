# A local go.work you create for your own multi-module editing is ignored
# so it never lands in a push. Airlock's builds resolve libs via GOPROXY,
# not go.work, so committing one wouldn't affect them anyway.
go.work
go.work.sum

# Tailwind build output — regenerated by the Docker build's templ + tailwindcss
# step. styles/app.css (the source) IS committed; this is only the artifact.
views/static/app.css
