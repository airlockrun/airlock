package views

import "github.com/airlockrun/agentsdk"

templ Layout(title string) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>{ title }</title>
			<link rel="stylesheet" href={ agentsdk.Assets.Pico }/>
			<script src={ agentsdk.Assets.HTMX }></script>
			<!-- Airlock auth: reload page on 401 to trigger the auth relay flow -->
			<script>
				document.addEventListener("htmx:responseError", function(e) {
					if (e.detail.xhr.status === 401) window.location.reload();
				});
			</script>
		</head>
		<body>
			<main class="container">
				{ children... }
			</main>
		</body>
	</html>
}
