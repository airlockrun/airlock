FROM golang:{{.GoVersion}} AS builder

WORKDIR /build

# Copy go.mod/go.sum first for layer caching
COPY go.mod go.sum* ./

# Libs come from two BuildKit contexts that airlock provides at build time:
#   libs-owned: agentsdk/goai/sol — overlay-able from a dev workspace via
#               AGENT_LIBS_PATH (live edits) or extracted from the
#               agent-builder image in prod.
#   libs-ext:   goose/templ — always extracted from the agent-builder image
#               (devs don't edit these).
#
# Splitting the contexts is required because BuildKit doesn't follow symlinks
# inside a context dir, so we can't merge owned + ext into one path.
COPY --from=libs-owned agentsdk /libs/agentsdk
COPY --from=libs-owned goai     /libs/goai
COPY --from=libs-owned sol      /libs/sol
COPY --from=libs-ext   goose    /libs/goose
COPY --from=libs-ext   templ    /libs/templ

# Download deps with cache mount — survives layer invalidation across builds
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download

# Copy source
COPY . .

# `go mod tidy` fills go.sum entries for the `tool` directive's transitive
# deps (plain `go mod download` skips them as of Go 1.24).
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    go mod tidy && go tool templ generate && go build -mod=mod -o /agent .

# Runtime
FROM airlock-agent-base

# Agent-specified system dependencies (optional). Same script the builder
# tested against locally. BuildKit cache mounts make repeat installs cheap;
# neither directory lands in the final image, so no manual cleanup needed.
COPY apt-deps.sh* /tmp/
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    if [ -f /tmp/apt-deps.sh ]; then bash /tmp/apt-deps.sh; fi

COPY --from=builder /agent /agent
COPY --from=builder /build/db/migrations /migrations

CMD ["/agent"]
