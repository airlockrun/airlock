# Default empty module proxy. Airlock's dev builds override this stage with
# `docker build --build-context goproxy=<dir>`, where <dir> is a generated
# file:// module proxy serving the airlock-owned libs (agentsdk/goai/sol) at
# their pinned versions from live source. On a prod build or a user clone
# (`docker build .`) the stage stays empty: GOPROXY's file:// entry returns
# 404 for every module and the build falls through to the public proxy. So
# the committed go.mod — which pins published versions and carries no
# replace directives — resolves normally.
FROM scratch AS goproxy

FROM golang:{{.GoVersion}} AS builder

WORKDIR /build

COPY go.mod go.sum* ./
COPY . .

# Resolve modules via the bind-mounted goproxy first, public proxy second.
# The goproxy bind is build-time only (not baked into a layer). The dev
# proxy serves the owned libs at versions that change content under a stable
# version string across builds, so evict those three from the module cache
# first — the cache keys by version and would otherwise serve stale source.
# Third-party modules stay cached. GONOSUMDB=* skips the checksum DB for the
# unpublished local versions. `go mod tidy` fills go.sum for the templ tool
# directive's transitive deps that `go mod download` skips as of Go 1.24.
RUN --mount=type=bind,from=goproxy,target=/goproxy \
    --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    chmod -R u+w /go/pkg/mod/cache/download/github.com/airlockrun /go/pkg/mod/github.com/airlockrun 2>/dev/null || true; \
    rm -rf /go/pkg/mod/cache/download/github.com/airlockrun/agentsdk \
           /go/pkg/mod/cache/download/github.com/airlockrun/goai \
           /go/pkg/mod/cache/download/github.com/airlockrun/sol \
           /go/pkg/mod/github.com/airlockrun/agentsdk@* \
           /go/pkg/mod/github.com/airlockrun/goai@* \
           /go/pkg/mod/github.com/airlockrun/sol@* 2>/dev/null || true; \
    GOPROXY="file:///goproxy,https://proxy.golang.org" GONOSUMDB="*" GOSUMDB=off \
    go mod tidy && go tool templ generate && go build -o /agent .

# Runtime
FROM {{.AgentBaseImage}}

# Agent-specified system setup (optional). Same script the builder tested
# against locally — runs as root so it can apt-get install, curl-bash an
# installer, pip install, drop binaries under /var/agent/bin/, whatever.
# BuildKit cache mounts keep apt repeat-installs cheap; neither directory
# lands in the final image.
COPY setup.sh* /tmp/
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    mkdir -p /var/agent/bin /var/agent/data && \
    if [ -f /tmp/setup.sh ]; then bash /tmp/setup.sh; fi

COPY --from=builder /agent /agent
COPY --from=builder /build/db/migrations /migrations

CMD ["/agent"]
