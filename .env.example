# Airlock environment config
#
# Three network audiences appear throughout:
#   (no suffix)  = Airlock process (host network)
#   _AGENT       = Agent containers (Docker network)
#   _PUBLIC      = Public internet (via reverse proxy)

# --- Public URL ---
export PUBLIC_URL=https://dev.airlock.run

# --- Postgres (Airlock's own connection) ---
# Use airlock_app, NOT the superuser airlock — see scripts/setup-db.sh
export DATABASE_URL=postgres://airlock_app:airlock_app@localhost:5432/airlock?sslmode=disable

# --- S3 / MinIO ---
export S3_URL=http://localhost:9090              # Airlock process → MinIO
export S3_URL_AGENT=http://minio:9000            # Agent containers → MinIO (Docker network)
export S3_URL_PUBLIC=https://s3.dev.airlock.run   # Public internet → MinIO (via Caddy)
export S3_ACCESS_KEY=airlock
export S3_SECRET_KEY=airlock123

# --- Database (agent schemas) ---
# Airlock creates per-agent Postgres schemas. Connections are built from these parts.
export DB_HOST=localhost          # Airlock process → Postgres
export DB_HOST_AGENT=postgres     # Agent containers → Postgres (Docker network)
export DB_PORT=5432
export DB_NAME=airlock
export DB_SSL_MODE=disable        # "require" in production

# --- JWT ---
export JWT_SECRET=dev-secret-change-in-production

# --- Encryption ---
# AES-256-GCM for provider API keys at rest. Generate with: openssl rand -hex 32
export ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# Optional: old key for rotation (set when rotating ENCRYPTION_KEY)
# export ENCRYPTION_KEY_OLD=

# --- Docker ---
export DOCKER_NETWORK=airlock-dev

# --- Reverse proxy ---
# Trust k8s pod network and Docker bridge for X-Forwarded-For / X-Real-IP.
# Comma-separated CIDRs, or "*" to trust all. Empty = disabled (use r.RemoteAddr as-is).
export REVERSE_PROXY_TRUSTED_PROXIES=10.42.0.0/16,172.16.0.0/12,172.21.0.0/16,
# How many proxy hops to walk in X-Forwarded-For (default: 1)
export REVERSE_PROXY_LIMIT=1

# --- Agent subdomain routing ---
# Bare host whose subdomains route to agents: {slug}.${AGENT_DOMAIN}.
# When unset, defaults to PUBLIC_URL's host (the typical case — Airlock and
# its agent subdomains share a parent zone). Set this only if you want
# agent subdomains under a different domain than Airlock itself.
#export AGENT_DOMAIN=dev.airlock.run

# --- Agent connectivity ---
export API_URL_AGENT=http://host.docker.internal:8080  # Agent containers → Airlock API
#export AGENT_LIBS_PATH=/home/myuser/airlockrun/devdir  # Dev mode: local libs path

# --- Optional ---
#export LLM_PROXY_URL=http://localhost:7373  # Route LLM calls through telescope

# Dev escape hatch: force base64 attachment delivery regardless of provider URL
# capability. Use this when the public URL isn't reachable from the model provider
# (e.g. running against a local S3 bucket without a tunnel).
#export FORCE_INLINE_ATTACHMENTS=true

# --- Activation ---
# On first run Airlock generates an activation code used to create the first
# admin user. The code is logged and also written to this file so
# `docker compose` users can grab it with: docker compose exec airlock cat <path>
# The file is auto-deleted after successful activation.
export ACTIVATION_CODE_FILE=/var/lib/airlock/activation_code.txt
