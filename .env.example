# Airlock self-host configuration — copy to .env and edit.
#
# Quickstart (default mode: on-demand Let's Encrypt, bundled Postgres + S3):
#   1. cp .env.example .env
#   2. Generate the three required secrets and paste them below:
#        openssl rand -hex 32     # → ENCRYPTION_KEY
#        openssl rand -hex 32     # → JWT_SECRET
#        openssl rand -hex 32     # → S3_SECRET_KEY
#   3. Set DOMAIN to a real domain you own.
#   4. Add a wildcard DNS A record at your DNS provider:
#        *.${DOMAIN}  →  <your server IP>
#   5. docker compose up -d
#   6. Get the first-run activation code:
#        docker compose exec airlock cat /var/lib/airlock/activation_code.txt
#      Sign in with this code to create the admin user.
#
# install.sh writes a correct .env for you (it picks TLS_MODE and infra
# interactively). This file documents every knob for manual setup.

# ================= Required =================

# Public domain. The wildcard DNS record covers per-agent subdomains.
DOMAIN=airlock.example.com

# AES-256-GCM key for at-rest encryption (provider API keys, webhook secrets,
# OAuth tokens). 64 hex chars. Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# JWT signing key. 64 hex chars. Generate: openssl rand -hex 32
JWT_SECRET=

# S3 secret key. Required — used as the RustFS root secret (bundled mode) and
# the key airlock signs requests with. Generate: openssl rand -hex 32
S3_SECRET_KEY=

# ================= TLS / ingress mode =================
#
# TLS_MODE selects caddy/Caddyfile.<mode>. The default (ondemand) needs nothing
# else. Each non-default mode has a section further down.
#
#   ondemand  Let's Encrypt HTTP-01, one cert issued per agent subdomain on
#             first request. No DNS credentials. Needs public ports 80+443.
#             Best below ~30 agents (LE rate limit: 50 certs/domain/week).
#   wildcard  One Cloudflare DNS-01 *.${DOMAIN} cert — no per-host rate limit.
#             See [wildcard].
#   tunnel    Cloudflare Tunnel; no public IP needed. See [tunnel].
#   internal  Caddy local CA for laptop/offline (airlock.localhost). See [laptop].
#   manual    Bring your own TLS cert. See [manual].
#   proxy     Sit behind your own nginx/traefik. See [proxy].
TLS_MODE=ondemand

# ================= Compose profiles =================
#
# Comma-separated, read automatically by docker compose. Controls which
# optional services start:
#   bundled-db  the bundled postgres (omit for an external Postgres)
#   bundled-s3  the bundled rustfs object store (omit for an external S3)
#   tunnel      the cloudflared sidecar (TLS_MODE=tunnel)
#   buildkit    the rootless BuildKit daemon (agent isolation)
# bundled-db and bundled-s3 are independent — bundle one and BYO the other.
COMPOSE_PROFILES=bundled-db,bundled-s3

# ================= Optional: bundled infra creds =================

# Postgres credentials for the bundled DB. Data lives in the pgdata volume —
# changing these on an existing install needs manual ALTER USER/DATABASE.
POSTGRES_USER=airlock
POSTGRES_PASSWORD=airlock
POSTGRES_DB=airlock

# S3 access key (the secret is S3_SECRET_KEY, required above).
S3_ACCESS_KEY=airlock

# ================= Optional: host ports =================
#
# Caddy's published ports. Defaults 80/443. Override when those are taken, or
# to bind loopback-only for proxy/tunnel modes. PUBLIC_URL must carry any
# non-default port so signed URLs validate.
# HTTP_PORT=80
# HTTPS_PORT=443

# Browser-facing URLs. Default to https://${DOMAIN} / https://s3.${DOMAIN};
# set explicitly when carrying a non-default port (laptop) or external S3.
# PUBLIC_URL=https://airlock.example.com
# S3_URL_PUBLIC=https://s3.airlock.example.com

# ----------------- [wildcard] Cloudflare DNS-01 -----------------
# TLS_MODE=wildcard. One *.${DOMAIN} cert via the Cloudflare DNS plugin — no
# per-subdomain rate limit. Needs the plugin caddy image (built locally) and a
# token scoped Zone:DNS:Edit + Zone:Read on this domain's zone.
#   docker build -f caddy/Dockerfile -t airlock-caddy-local .
# CADDY_IMAGE=airlock-caddy-local
# CLOUDFLARE_API_TOKEN=
# ACME_EMAIL=you@example.com   # optional, cert-expiry notices

# ----------------- [tunnel] Cloudflare Tunnel -----------------
# TLS_MODE=tunnel + COMPOSE_PROFILES=bundled-db,bundled-s3,tunnel. Create a tunnel in the
# CF Zero-Trust dashboard, route DOMAIN / *.DOMAIN / s3.DOMAIN → http://caddy:80,
# paste the token here. The CF edge terminates the *.${DOMAIN} wildcard TLS.
# Bind caddy loopback-only since ingress is the tunnel:
#   HTTP_PORT=127.0.0.1:8080
#   HTTPS_PORT=127.0.0.1:8443
# TUNNEL_TOKEN=

# ----------------- [manual] Bring your own cert -----------------
# TLS_MODE=manual. Caddy serves the cert+key you provide (no issuance). The
# cert MUST be a wildcard covering apex + *.${DOMAIN} (+ s3.${DOMAIN}) — a
# single-host cert breaks per-agent {slug}.${DOMAIN} routing. Drop the files in
# TLS_CERT_DIR (mounted at /certs) and point the *_FILE vars at them.
# TLS_CERT_DIR=./certs
# TLS_CERT_FILE=/certs/cert.pem
# TLS_KEY_FILE=/certs/key.pem

# ----------------- [proxy] Behind a central reverse proxy -----------------
# TLS_MODE=proxy. Your existing nginx/traefik terminates TLS for DOMAIN,
# *.${DOMAIN}, s3.${DOMAIN} (it must hold the *.${DOMAIN} wildcard cert) and
# forwards them as HTTP to caddy. Bind caddy loopback-only and trust the proxy:
#   HTTP_PORT=127.0.0.1:8080
#   HTTPS_PORT=127.0.0.1:8443
#   REVERSE_PROXY_TRUSTED_PROXIES=<proxy CIDR, e.g. 10.0.0.0/8, or *>
#   PUBLIC_URL=https://airlock.example.com

# ----------------- [laptop] Local-only try-out -----------------
# TLS_MODE=internal with airlock.localhost (resolves to 127.0.0.1 via RFC 6761,
# no DNS). Caddy's local CA; first visit warns until you trust it:
#   docker compose exec caddy caddy trust
#   DOMAIN=airlock.localhost
#   TLS_MODE=internal
#   HTTP_PORT=24080
#   HTTPS_PORT=24443
#   PUBLIC_URL=https://airlock.localhost:24443
#   S3_URL_PUBLIC=https://s3.airlock.localhost:24443
#   FORCE_INLINE_ATTACHMENTS=true   # *.localhost isn't internet-reachable

# ----------------- [external DB / S3] -----------------
# Use your own Postgres and/or object store instead of the bundled services.
# Drop the matching profile(s) from COMPOSE_PROFILES — independently, so e.g.
# bundled pgvector + external AWS S3 is COMPOSE_PROFILES=bundled-db.
#
# External Postgres (drop bundled-db). Run db/init/ on it once (the
# create_agent_role() helper + the vector extension):
#   DATABASE_URL=postgres://user:pass@db.example.com:5432/airlock?sslmode=require
#   DB_HOST=db.example.com
#   DB_HOST_AGENT=db.example.com
#   DB_SSL_MODE=require
#
# External S3 / object store (drop bundled-s3). Path-style addressing, so any
# S3-compatible provider works — AWS, Cloudflare R2, Backblaze B2, Mega S4, MinIO:
#   S3_URL=https://s3.eu-central-1.s4.mega.io   # the provider's endpoint
#   S3_URL_PUBLIC=https://s3.eu-central-1.s4.mega.io   # usually the same
#   S3_ACCESS_KEY=...        # (S3_SECRET_KEY set in the Required section)
#   S3_BUCKET=my-airlock-bucket   # your bucket name (default: airlock)
#   S3_REGION=eu-central-1        # your provider's region (default: us-east-1)
#
# Example — bundled Postgres, external S3:  COMPOSE_PROFILES=bundled-db
# Example — both external:                  COMPOSE_PROFILES=

# ================= Advanced =================

# Enable the Discord chat bridge. Off by default (the gateway integration isn't
# actively tested). Telegram is unaffected.
# ENABLE_DISCORD=true

# Old encryption key for rotation. Set the previous value here while rotating
# ENCRYPTION_KEY so airlock can decrypt + re-encrypt; remove when done.
# ENCRYPTION_KEY_OLD=

# ----------------- Agent isolation (see docs/agent-isolation.md) -----------------

# Rootless BuildKit for agent image builds (untrusted setup.sh runs as root
# inside buildkitd, not on the host daemon). Empty = legacy host docker build.
# Enable by setting the socket AND adding `buildkit` to COMPOSE_PROFILES.
# Needs host unprivileged userns + /dev/fuse.
# BUILDKIT_HOST=tcp://buildkitd:1234

# Run agents under gVisor (runsc) for kernel-escape containment (requires runsc
# registered as a Docker runtime). Empty = runc + the default hardening.
# AGENT_SANDBOX=gvisor

# Optional per-agent memory cap (e.g. 512m, 2g). Empty = unlimited; the host is
# still protected from collective pressure via OomScoreAdj.
# AGENT_MEMORY_LIMIT=

# Namespaces every Docker resource this airlock owns so instances sharing the
# host daemon never reap each other's resources. Default "airlock" is fine for
# a single instance. A SECOND stack on the same daemon needs a DISTINCT value
# (and its own networks/volumes/ports). See docs/agent-isolation.md.
# AIRLOCK_INSTANCE_ID=airlock

# ----------------- Logging -----------------

# Log format. Default is a human-readable console format (readable in
# `docker logs`, plain wall-clock timestamps). Set to "json" for structured
# JSON with ISO8601 timestamps — for log shippers / aggregators.
# LOG_FORMAT=json

# Log verbosity. Default is info; set "debug" for verbose diagnostics.
# LOG_LEVEL=debug
