# Airlock self-host configuration.
#
# Quickstart:
#   1. cp .env.example .env
#   2. Generate the two required secrets and paste them below:
#        openssl rand -hex 32     # → ENCRYPTION_KEY
#        openssl rand -hex 32     # → JWT_SECRET
#   3. Set DOMAIN to a real domain you own.
#   4. Add a wildcard DNS A record at your DNS provider:
#        *.${DOMAIN}  →  <your server IP>
#   5. docker compose up -d
#   6. Get the first-run activation code:
#        docker compose exec airlock cat /var/lib/airlock/activation_code.txt
#      Sign in with this code to create the admin user.

# ---------- Required ----------

# Public domain. Caddy uses this to issue TLS certs from Let's Encrypt
# (HTTP-01 challenge). Both ports 80 and 443 must be reachable from the
# public internet. The wildcard DNS record covers per-agent subdomains.
DOMAIN=airlock.example.com

# AES-256-GCM key for at-rest encryption (provider API keys, webhook
# secrets, OAuth tokens). 64 hex chars. Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# JWT signing key. 64 hex chars. Generate: openssl rand -hex 32
JWT_SECRET=

# ---------- Optional ----------

# Postgres credentials. The defaults work fine for self-host. Data lives
# in a named volume (pgdata) — changing these on an existing install
# requires manual ALTER USER + ALTER DATABASE inside the container.
POSTGRES_USER=airlock
POSTGRES_PASSWORD=airlock
POSTGRES_DB=airlock

# MinIO admin credentials. These also serve as the S3 access key/secret
# airlock uses internally. Change MINIO_ROOT_PASSWORD before any public
# exposure of the MinIO console.
MINIO_ROOT_USER=airlock
MINIO_ROOT_PASSWORD=changeme-in-production

# ---------- Advanced ----------

# Old encryption key for rotation. When rotating ENCRYPTION_KEY, set the
# previous value here so airlock can decrypt existing ciphertexts and
# re-encrypt with the new key. Remove once rotation is complete.
# ENCRYPTION_KEY_OLD=

# Let's Encrypt account email — set this and uncomment the matching line
# in Caddyfile to receive cert expiry warnings.
# ACME_EMAIL=
