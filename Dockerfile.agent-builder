# Dockerfile.agent-builder — standalone build of the toolserver image.
#
# Build context is this repo's root. From a fresh airlock/ checkout:
#   docker build -f Dockerfile.agent-builder -t agent-builder:v0.1.0 .
#
# Populates /libs/{agentsdk,goai,sol,goose,templ} from the public Go module
# proxy at the pinned versions. Override at build time with --build-arg
# AGENTSDK_VERSION=v0.2.0 (etc.). The CLI binaries (sol, toolserver, goose,
# templ) are all built from the baked /libs/ source so the lib version sol
# sees and the CLI version it can shell out to are guaranteed identical.
#
# Cross-module dev (live edits) uses hq/Dockerfile.agent-builder instead.

ARG SQLC_VERSION=1.30.0
FROM sqlc/sqlc:${SQLC_VERSION} AS sqlc

FROM golang:1.26-trixie

ENV XDG_CACHE_HOME=/var/agent/cache

ARG AGENTSDK_VERSION=v0.4.0-rc.30
ARG GOAI_VERSION=v0.1.5-rc.10
ARG SOL_VERSION=v0.1.8-rc.9
ARG GOOSE_VERSION=v3.27.1
ARG TEMPL_VERSION=v0.3.1020
ARG TAILWIND_VERSION=v4.1.0
ARG DAISYUI_VERSION=v5.5.23
ARG SQLC_VERSION=1.30.0

COPY --from=sqlc /workspace/sqlc /usr/local/bin/sqlc
RUN apt-get update && apt-get install -y --no-install-recommends \
        git ripgrep postgresql-client curl ca-certificates sudo && \
    rm -rf /var/lib/apt/lists/*

# Toolserver UID resolution + sudo.
#
# The toolserver runs as the airlock host UID so files it writes into
# the bind-mounted workspace are host-owned. That UID has no entry in
# the image's account databases; the entrypoint self-registers it into
# /etc/passwd + /etc/shadow on container start (both made world-writable
# below so the non-root entrypoint can append).
#
# sudo is unrestricted (NOPASSWD: ALL) and that is the honest config —
# it is NOT a privilege boundary. run-setup execs an LLM-authored
# setup.sh from the current workspace as root, so the codegen agent has root in this
# container by design (it must, to install build dependencies). The
# real boundary is the container itself: ephemeral, one per build, no
# --privileged, no docker socket, no host mounts. World-writable
# account files change nothing — the agent already has effective root
# here, and the base image's /etc/shadow holds no real password
# hashes. run-setup stays as a convenience the build prompt
# points at for applying setup.sh.
COPY --chmod=0755 scripts/agent-builder-entrypoint.sh /usr/local/bin/agent-builder-entrypoint
RUN chmod 0666 /etc/passwd /etc/shadow && \
    printf '#!/bin/bash\nset -euo pipefail\nexec bash ./setup.sh "$@"\n' \
        > /usr/local/bin/run-setup && \
    chmod 0755 /usr/local/bin/run-setup && \
    echo 'ALL ALL=(root) NOPASSWD: ALL' \
        > /etc/sudoers.d/99-airlock-builder && \
    chmod 0440 /etc/sudoers.d/99-airlock-builder && \
    mkdir -p /var/agent/bin /var/agent/data /var/agent/cache && \
    chmod 0777 /var/agent/bin /var/agent/data /var/agent/cache

# Materialize /libs/* from the Go module proxy at pinned versions. Files come
# out 0444 from the cache; chmod so any tooling that pokes at writability
# inside /libs/ doesn't blow up. GOMODCACHE is stripped after extraction —
# subsequent CLI builds repopulate a small cache, which is fine.
RUN mkdir -p /libs && \
    mkdir /tmp/libs-fetch && cd /tmp/libs-fetch && \
    go mod init libs-fetcher && \
    go mod download -x \
        github.com/airlockrun/agentsdk@${AGENTSDK_VERSION} \
        github.com/airlockrun/goai@${GOAI_VERSION} \
        github.com/airlockrun/sol@${SOL_VERSION} \
        github.com/pressly/goose/v3@${GOOSE_VERSION} \
        github.com/a-h/templ@${TEMPL_VERSION} && \
    cp -r "$(go env GOMODCACHE)/github.com/airlockrun/agentsdk@${AGENTSDK_VERSION}" /libs/agentsdk && \
    cp -r "$(go env GOMODCACHE)/github.com/airlockrun/goai@${GOAI_VERSION}"         /libs/goai && \
    cp -r "$(go env GOMODCACHE)/github.com/airlockrun/sol@${SOL_VERSION}"           /libs/sol && \
    cp -r "$(go env GOMODCACHE)/github.com/pressly/goose/v3@${GOOSE_VERSION}"       /libs/goose && \
    cp -r "$(go env GOMODCACHE)/github.com/a-h/templ@${TEMPL_VERSION}"              /libs/templ && \
    chmod -R u+w /libs && \
    rm -rf /tmp/libs-fetch "$(go env GOMODCACHE)"

# Build CLI binaries straight from /libs/ source so every command matches its
# library version.
RUN cd /libs/sol   && go build -o /usr/local/bin/sol        ./cmd/sol && \
                      go build -o /usr/local/bin/toolserver ./cmd/toolserver
RUN cd /libs/goose && go build -o /usr/local/bin/goose      ./cmd/goose
RUN cd /libs/templ && go build -o /usr/local/bin/templ      ./cmd/templ

# Tailwind v4 standalone — Rust binary, no Node. The air CLI projects it
# into each repo's .airlock/toolchain before running the build chain.
RUN mkdir -p ${XDG_CACHE_HOME}/airlock/toolchain/sqlc/${SQLC_VERSION}/linux-amd64 && \
    cp /usr/local/bin/sqlc ${XDG_CACHE_HOME}/airlock/toolchain/sqlc/${SQLC_VERSION}/linux-amd64/sqlc
RUN mkdir -p ${XDG_CACHE_HOME}/airlock/toolchain/tailwindcss/${TAILWIND_VERSION}/linux-amd64
ADD --chmod=0755 https://github.com/tailwindlabs/tailwindcss/releases/download/${TAILWIND_VERSION}/tailwindcss-linux-x64 ${XDG_CACHE_HOME}/airlock/toolchain/tailwindcss/${TAILWIND_VERSION}/linux-amd64/tailwindcss

# DaisyUI v5 — Tailwind plugin shipped as a self-contained .mjs that the
# standalone Tailwind binary loads via `@plugin "..."` (no Node runtime).
# The air CLI projects these cached files into each repo's .airlock/toolchain.
RUN mkdir -p ${XDG_CACHE_HOME}/airlock/toolchain/daisyui/${DAISYUI_VERSION}
ADD --chmod=0644 https://github.com/saadeghi/daisyui/releases/download/${DAISYUI_VERSION}/daisyui.mjs       ${XDG_CACHE_HOME}/airlock/toolchain/daisyui/${DAISYUI_VERSION}/daisyui.mjs
ADD --chmod=0644 https://github.com/saadeghi/daisyui/releases/download/${DAISYUI_VERSION}/daisyui-theme.mjs ${XDG_CACHE_HOME}/airlock/toolchain/daisyui/${DAISYUI_VERSION}/daisyui-theme.mjs
RUN chmod -R a+rwX ${XDG_CACHE_HOME}/airlock/toolchain

# Validate that the installed bundle emits both light and dark built-in themes.
# Theme authoring guidance comes from the version-matched daisyui-config skill.
COPY --chmod=0755 scripts/check-daisyui-themes /tmp/check-daisyui-themes
RUN /tmp/check-daisyui-themes && rm /tmp/check-daisyui-themes

# Version-matched coding skills ship in agentsdk so Airlock codegen and external
# harnesses consume one checked-in bundle. Fail the image build if that bundle is
# incomplete or still contains the incompatible DaisyUI install subskill.
RUN mkdir -p /usr/local/lib/agent-skills/skills && \
    cp -r /libs/agentsdk/scaffold/skills/. /usr/local/lib/agent-skills/skills/ && \
    test -f /usr/local/lib/agent-skills/skills/daisyui/SKILL.md && \
    test ! -e /usr/local/lib/agent-skills/skills/daisyui/install && \
    test -f /usr/local/lib/agent-skills/skills/templ/reference/03-syntax-and-usage/06-if-else.md && \
    test -f /usr/local/lib/agent-skills/skills/htmx/reference/docs.md && \
    chmod -R a+rX /usr/local/lib/agent-skills

# Go cache dirs writable by the host UID — Docker volumes mount as root,
# but the toolserver runs as the host user.
RUN mkdir -p /tmp/go-mod /tmp/go-cache && chmod 777 /tmp/go-mod /tmp/go-cache

WORKDIR /workspace

# Self-register the runtime UID into /etc/passwd before exec'ing the
# toolserver (or whatever Cmd airlock supplies). See the sudo block above.
ENTRYPOINT ["/usr/local/bin/agent-builder-entrypoint"]
