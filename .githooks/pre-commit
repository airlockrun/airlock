#!/usr/bin/env bash
# Pre-commit hook — gates, all also enforced in CI:
#
#   1. Version-invariant check (Dockerfile↔go.mod drift, compose tags,
#      README pin, version.go). Same script CI runs on tag push.
#   2. Migration immutability — a migration shipped in a release tag
#      cannot be changed or deleted (goose has no checksum; a silent
#      diverge otherwise). New/in-dev migrations are unrestricted.
#   3. Dependency licenses — every dep compiled into a distributed binary
#      must be permissive (no copyleft/source-available sneaking in).
#   4. Notices freshness — THIRD_PARTY_NOTICES files match the dep graph.
#   5. gofmt on the Go files staged for this commit. Blocks the commit
#      if any need formatting; does NOT auto-rewrite (explicit, no
#      surprise edits to your working tree).
#   6. airlockvet on api/ — nodbq (handlers route through service/) +
#      writeproto (handlers emit proto, not JSON). Skipped when no api/
#      file is staged; otherwise a single un-annotated violation blocks
#      the commit.
#
# Enable for this clone (one-time):
#   git config core.hooksPath .githooks
#
# Skip a single commit:
#   git commit --no-verify

set -e

repo_root=$(git rev-parse --show-toplevel)

"$repo_root/scripts/check-versions.sh"
"$repo_root/scripts/check-migrations.sh"
"$repo_root/scripts/check-licenses.sh"
"$repo_root/scripts/check-notices.sh"

# Only the .go files staged in this commit (Added/Copied/Modified/Renamed),
# so an unrelated unformatted file elsewhere in the tree doesn't block you.
staged_go=$(git diff --cached --name-only --diff-filter=ACMR -- '*.go')
if [ -n "$staged_go" ]; then
	unformatted=$(gofmt -l $staged_go)
	if [ -n "$unformatted" ]; then
		echo "ERROR: these staged Go files are not gofmt-formatted:" >&2
		echo "$unformatted" | sed 's/^/  /' >&2
		echo >&2
		echo "Fix with:" >&2
		echo "  gofmt -w $unformatted" >&2
		echo "then re-stage and commit." >&2
		exit 1
	fi
fi

# airlockvet only matters when this commit touches api/ or agentapi/.
# The analyzer operates package-wide (any single file change can shift
# line numbers the annotations sit next to), so scope by "did the commit
# touch one of those packages?" rather than passing individual file
# paths.
staged_vet=$(git diff --cached --name-only --diff-filter=ACMR -- 'api/*.go' 'agentapi/*.go')
if [ -n "$staged_vet" ]; then
	if ! go run "$repo_root/cmd/airlockvet" ./api/... ./agentapi/...; then
		echo >&2
		echo "ERROR: airlockvet rejected the commit." >&2
		echo "Route the call through service/{domain} (and authz.Authorize)," >&2
		echo "switch JSON for proto, move the wire type to agentsdk," >&2
		echo "or annotate the line with a reason:" >&2
		echo "  // airlockvet:allow-dbq reason: ..." >&2
		echo "  // airlockvet:allow-writejson reason: ..." >&2
		echo "  // airlockvet:allow-agentwire reason: ..." >&2
		exit 1
	fi
fi

# Build / correctness gates (go.work overlay resolves sibling libs).
go vet ./... || { echo "ERROR: go vet failed" >&2; exit 1; }
go test ./... || { echo "ERROR: go test failed" >&2; exit 1; }
echo "airlock gofmt/vet/test: OK"
