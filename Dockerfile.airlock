# Dockerfile.airlock — standalone build of the airlock API server.
#
# Build context is this repo's root. From a fresh clone:
#   docker build -f Dockerfile.airlock -t airlock .
#
# Cross-module dev (live edits across goai/sol/agentsdk) is done outside
# Docker via go.work in the meta-repo; this image always pulls the goai/sol/
# agentsdk versions pinned in go.mod from the public Go module proxy.
#
# To temporarily test this image against a local checkout of one of the
# sibling libs, add a `replace` line to go.mod and use BuildKit's
# --build-context to expose the source, e.g.:
#   docker build --build-context goai=../goai -f Dockerfile.airlock -t airlock-dev .
# (and a matching `replace github.com/airlockrun/goai => /goai` in go.mod).

# --- Builder ---
FROM golang:1.26-alpine AS builder

RUN apk add --no-cache git

WORKDIR /src

# Pre-fetch deps so this layer caches across source-only edits.
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -o /airlock ./cmd/airlock

# --- Runtime ---
FROM alpine:3.21

# Runtime tooling airlock shells out to:
#   ca-certificates — TLS root store for outbound HTTPS
#   ffmpeg          — trigger/transcode.go converts ogg/opus voice notes from
#                     bridges into MP3 (gpt-4o-transcribe rejects ogg/opus)
#   docker-cli +    — orchestrate agent containers and run per-agent
#   docker-cli-buildx  docker build (--build-context multi-source). The
#                     container talks to the host docker daemon via the
#                     mounted socket; binaries here are just the client.
#   git             — manages the agent monorepo (git init/add/commit per
#                     agent build). Default user.email/user.name set so
#                     `git commit` doesn't error out on first use.
RUN apk add --no-cache ca-certificates ffmpeg docker-cli docker-cli-buildx git wget \
    && git config --global user.email "airlock@localhost" \
    && git config --global user.name "Airlock"

COPY --from=builder /airlock /airlock
# Third-party license attributions for the deps compiled into the binary
# (required by their MIT/BSD/Apache terms to travel with the distribution).
COPY THIRD_PARTY_NOTICES.md /THIRD_PARTY_NOTICES.md

EXPOSE 8080
ENTRYPOINT ["/airlock"]
CMD ["serve"]
