# Develop-against-source Caddy config.
#
# Pairs with docker-compose.dev.yml: postgres + rustfs + caddy run in
# containers; airlock runs natively on the host (`go run ./cmd/airlock`)
# and vite REBUILDS in watch mode (`pnpm watch` = `vite build --watch`)
# emitting static files to frontend/dist, which caddy then serves
# directly. No dev server is exposed on the network — the entire vite
# dev-server attack surface (HMR WS, /@fs/, /@id/, etc.) is gone.
#
# Trade-off vs the old `vite dev`: no HMR (manual browser refresh on
# edits) in exchange for closing every vite-dev-server CVE class. After
# CVE-2026-39363 (WS-based fs.deny bypass), this is the right default.
#
# Env knobs:
#   DOMAIN              public hostname (airlock.localhost / your-domain)
#   AIRLOCK_UPSTREAM    Caddy → airlock binary (default host.docker.internal:8080)
#   ACME_EMAIL          set → LE issuance with this contact; unset → Caddy's
#                       local CA (no internet/laptop dev, browsers warn).
#                       The compose file expands this to the two lines
#                       below — exactly one is a real directive per state;
#                       the other is a Caddyfile comment (#) that no-ops.

{
	{$ACME_EMAIL_LINE}
	{$LOCAL_CERTS_LINE}

	on_demand_tls {
		# Same callback shape as prod (api/caddy.go). The dev /caddy/ask
		# is the natively-running airlock binary, reached through the
		# host gateway.
		ask http://{$AIRLOCK_UPSTREAM}/caddy/ask
	}
}

# Apex domain: SPA static files + airlock REST/WebSocket API.
{$DOMAIN} {
	root * /srv/dist

	# /auth/relay is a frontend SPA route (landing page for the
	# subdomain relay-login flow). Matched BEFORE @backend so the
	# /auth/* matcher doesn't swallow it. Serves index.html so the
	# SPA router picks up the path. The backend serves
	# POST /auth/relay-code, which the SPA calls from this page.
	@spa_relay path /auth/relay
	handle @spa_relay {
		rewrite * /index.html
		file_server
	}

	@backend path /api/* /auth/* /auth-external /ws /webhooks/* /health /.well-known/* /oauth/*
	handle @backend {
		reverse_proxy {$AIRLOCK_UPSTREAM}
	}

	# Catch-all: static asset if it exists, else index.html (SPA fallback
	# for client-side routing — /agents/42, /login, etc.).
	handle {
		try_files {path} /index.html
		file_server
	}
}

# Public S3 — uses on_demand for the same reason prod does: a wildcard
# block below makes Caddy skip eager issuance for s3.${DOMAIN} due to
# overlap. on_demand sidesteps that; cert issues lazily on first request.
# header_up Host preserves the original Host so RustFS's presigned URL
# signature stays valid.
s3.{$DOMAIN} {
	tls {
		on_demand
	}
	reverse_proxy rustfs:9000 {
		header_up Host {host}
	}
}

# Wildcard subdomains: per-agent custom routes ({slug}.${DOMAIN}).
# Caddy terminates TLS via on-demand issuance per subdomain; airlock's
# SubdomainProxy handles routing internally.
*.{$DOMAIN} {
	tls {
		on_demand
	}
	reverse_proxy {$AIRLOCK_UPSTREAM}
}
